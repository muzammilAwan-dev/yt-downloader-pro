{
  "manifest_version": 3,
  "name": "YT Downloader Pro",
  "version": "5.3.0",
  "description": "Premium YouTube downloader with native yt-dlp integration. Features zero-server architecture, age-restriction bypass, and playlist support.",
  "author": "muzammilAwan-dev",
  "homepage_url": "https://github.com/muzammilAwan-dev/yt-downloader-pro",
  
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "YT Downloader Pro - Launch UI"
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "permissions": [
    "activeTab",
    "storage",
    "notifications",
    "cookies"
  ],
  
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://youtu.be/*"
  ],
  
  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ]
}